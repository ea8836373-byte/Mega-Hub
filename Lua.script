local Scroll = Instance.new("ScrollingFrame", TMain); Scroll.Size = UDim2.new(1, -10, 0, 140); Scroll.Position = UDim2.new(0, 5, 0, 5); Scroll.BackgroundTransparency = 1; Scroll.CanvasSize = UDim2.new(0, 0, 2, 0)
local TL = Instance.new("TextButton", TMain); TL.Text = "TL"; TL.Size = UDim2.new(0.8, 0, 0, 35); TL.Position = UDim2.new(0.1, 0, 0.75, 0); TL.BackgroundColor3 = Color3.fromRGB(0, 120, 255); TL.TextColor3 = Color3.new(1, 1, 1); TL.Font = Enum.Font.GothamBold; Instance.new("UICorner", TL)

local targetPos = nil
local points = {
    {"Shop", Vector3.new(97.79, 1339.98, -75.49)},
    {"Halloween 2021", Vector3.new(668.42, 1384.78, -262.89)},
    {"Dark Shop", Vector3.new(-133.18, 1335.56, -8.83)},
    {"Rebirth Shop", Vector3.new(-218.10, 1335.73, -6.62)},
    {"Salon", Vector3.new(-184.90, 1339.98, 62.84)}
}

for i, p in ipairs(points) do
    local b = Instance.new("TextButton", Scroll); b.Text = p[1]; b.Size = UDim2.new(1, 0, 0, 30); b.Position = UDim2.new(0, 0, 0, (i-1)*33); b.BackgroundColor3 = Color3.fromRGB(35, 35, 35); b.TextColor3 = Color3.new(1, 1, 1)
    b.MouseButton1Click:Connect(function() targetPos = p[2]; TL.Text = "TL TO " .. p[1] end)
end
TL.MouseButton1Click:Connect(function() if targetPos and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(targetPos) end end)

-- LOOPS
task.spawn(function()
    while true do
        pcall(function()
            if ghostActive then
                local enemies = workspace.Areas["Spooky Path"].EnemyHolder:GetChildren()
                for i = 1, 3 do if enemies[i] and enemies[i].Name:find("Ghost") then ReplicatedStorage.Remotes.Punch:FireServer(enemies[i]) end end
            end
            
            if rebirthActive then
                ReplicatedStorage.Remotes.Rebirth:FireServer()
                ReplicatedStorage.Remotes.Punch:FireServer(unpack({Instance.new("Model", nil)}))
            end

            if upgradeActive then
                if LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(7730.49, 3273.26, -191270.30)
                end
                VirtualUser:CaptureController()
                VirtualUser:ClickButton1(Vector2.new(0,0))
                ReplicatedStorage.Remotes.Upgrade:FireServer()
                ReplicatedStorage.Remotes.Purchase:FireServer()
            end
        end)
        task.wait(0.3)
    end
end)
