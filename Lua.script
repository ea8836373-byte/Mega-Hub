local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local VirtualUser = game:GetService("VirtualUser")

-- PULIZIA GUI PRECEDENTI
for _, gui in pairs(game.CoreGui:GetChildren()) do
    if gui.Name == "FarmGhost" or gui.Name == "MiniTele" or gui.Name == "AutoRebirthGUI" or gui.Name == "AutoUpgradeGUI" or gui.Name == "FarmBig" then
        gui:Destroy()
    end
end

local function drag(frame)
    local dragging, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = frame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
end

-- 👻 TAB 1: GHOST FARM
local GhostGui = Instance.new("ScreenGui", game.CoreGui); GhostGui.Name = "FarmGhost"
local GMain = Instance.new("Frame", GhostGui); GMain.Size = UDim2.new(0, 160, 0, 75); GMain.Position = UDim2.new(0.05, 0, 0.1, 0); GMain.BackgroundColor3 = Color3.fromRGB(30, 30, 30); drag(GMain); Instance.new("UICorner", GMain)
local GTik = Instance.new("TextButton", GMain); GTik.Size = UDim2.new(0, 140, 0, 40); GTik.Position = UDim2.new(0.06, 0, 0.25, 0); GTik.Text = "GHOST: OFF"; GTik.BackgroundColor3 = Color3.fromRGB(50, 50, 50); GTik.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", GTik)
local ghostActive = false
GTik.MouseButton1Click:Connect(function() ghostActive = not ghostActive; GTik.Text = ghostActive and "GHOST: ON" or "GHOST: OFF"; GTik.BackgroundColor3 = ghostActive and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(50, 50, 50) end)

